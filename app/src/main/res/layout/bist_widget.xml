<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/widget_header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="BIST FAVORİLER"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <ImageView
            android:id="@+id/widget_refresh_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:contentDescription="Yenile"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_refresh" />
    </RelativeLayout>

    <FrameLayout
        android:id="@+id/widget_header_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1F2937"
        android:layout_marginBottom="8dp" />

    <!-- No Favorites Text -->
    <TextView
        android:id="@+id/no_favorites_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Favori hisseniz bulunmuyor.\nUygulamadan ekleyebilirsiniz."
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- List of Favorites (up to 5 items) -->
    <LinearLayout
        android:id="@+id/widget_items_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Item 1 -->
        <RelativeLayout
            android:id="@+id/item1_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:id="@+id/item1_price_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentEnd="true"
                android:gravity="end">
                <TextView
                    android:id="@+id/item1_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F9FAFB"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/item1_change"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/item1_price_container"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/item1_hisse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F9FAFB"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/item1_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Item 2 -->
        <RelativeLayout
            android:id="@+id/item2_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:id="@+id/item2_price_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentEnd="true"
                android:gravity="end">
                <TextView
                    android:id="@+id/item2_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F9FAFB"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/item2_change"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/item2_price_container"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/item2_hisse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F9FAFB"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/item2_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Item 3 -->
